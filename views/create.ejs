<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">

    <div class="d-flex align-items-center mb-4">
      <a href="/songs" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
      </a>
      <h2 class="mb-0">
        <i class="bi bi-plus-circle-fill text-primary me-2"></i>Agregar canción
      </h2>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
      </div>
    <% } %>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <form action="/songs" method="POST" novalidate>

          <div class="mb-3">
            <label for="title" class="form-label">
              Título <span class="text-danger">*</span>
            </label>
            <input
              type="text"
              class="form-control"
              id="title"
              name="title"
              placeholder="Ej. Bohemian Rhapsody"
              value="<%= typeof formData !== 'undefined' && formData.title ? formData.title : '' %>"
              required
            >
          </div>

          <div class="mb-3">
            <label for="artist" class="form-label">
              Artista <span class="text-danger">*</span>
            </label>
            <input
              type="text"
              class="form-control"
              id="artist"
              name="artist"
              placeholder="Ej. Queen"
              value="<%= typeof formData !== 'undefined' && formData.artist ? formData.artist : '' %>"
              required
            >
          </div>

          <div class="mb-3">
            <label for="album" class="form-label">Álbum</label>
            <input
              type="text"
              class="form-control"
              id="album"
              name="album"
              placeholder="Ej. A Night at the Opera"
              value="<%= typeof formData !== 'undefined' && formData.album ? formData.album : '' %>"
            >
          </div>

          <div class="row">
            <div class="col-md-7 mb-3">
              <label for="genre" class="form-label">Género</label>
              <input
                type="text"
                class="form-control"
                id="genre"
                name="genre"
                placeholder="Ej. Rock"
                value="<%= typeof formData !== 'undefined' && formData.genre ? formData.genre : '' %>"
              >
            </div>
            <div class="col-md-5 mb-3">
              <label for="duration" class="form-label">Duración</label>
              <input
                type="text"
                class="form-control"
                id="duration"
                name="duration"
                placeholder="Ej. 5:55"
                value="<%= typeof formData !== 'undefined' && formData.duration ? formData.duration : '' %>"
              >
            </div>
          </div>

          <div class="d-flex justify-content-end gap-2 mt-4">
            <a href="/songs" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i>Guardar canción
            </button>
          </div>

        </form>
      </div>
    </div>

  </div>
</div>