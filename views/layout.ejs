<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Music Library' %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
  >

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/songs">
        <i class="bi bi-music-note-beamed me-2"></i>Music Library
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNavbar"
        aria-controls="mainNavbar"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="/songs">
              <i class="bi bi-list-ul me-1"></i>Canciones
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/songs/favorites">
              <i class="bi bi-star-fill me-1"></i>Favoritas
            </a>
          </li>
        </ul>

        <form class="d-flex me-3" action="/songs/search" method="GET" role="search">
          <input
            class="form-control form-control-sm"
            type="search"
            name="q"
            placeholder="Buscar por título, artista o género..."
            aria-label="Buscar"
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
          >
          <button class="btn btn-outline-light btn-sm ms-2" type="submit">
            <i class="bi bi-search"></i>
          </button>
        </form>

        <a href="/songs/new" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i>Agregar canción
        </a>
      </div>
    </div>
  </nav>

  <main class="container my-4">
    <%- body %>
  </main>

  <footer class="text-center text-muted py-4 mt-5 border-top">
    <small>&copy; <%= new Date().getFullYear() %> Music Library &mdash; Proyecto CRUD con Node.js, Express &amp; SQLite</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script src="/js/main.js"></script>
</body>
</html>